  "htmlContent": "<!DOCTYPE html>\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Quiz Interface - Amazon PPC Mastery</title>\n<link href=\"https://fonts.googleapis.com\" rel=\"preconnect\"/>\n<link crossorigin=\"\" href=\"https://fonts.gstatic.com\" rel=\"preconnect\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        \"primary\": \"#2463eb\",\n                        \"background-light\": \"#f6f6f8\",\n                        \"background-dark\": \"#111621\",\n                        \"surface-light\": \"#ffffff\",\n                        \"surface-dark\": \"#1a2230\",\n                    },\n                    fontFamily: {\n                        \"display\": [\"Inter\", \"sans-serif\"]\n                    },\n                    borderRadius: {\n                        \"DEFAULT\": \"0.25rem\",\n                        \"lg\": \"0.5rem\",\n                        \"xl\": \"0.75rem\",\n                        \"2xl\": \"1rem\",\n                        \"full\": \"9999px\"\n                    },\n                },\n            },\n        }\n    </script>\n<style>.custom-radio:checked {\n    background-image: url(https://lh3.googleusercontent.com/aida-public/AB6AXuBJwPtXovleycAD9ECUgvKMKma5NurQoGcXREHb3cebxnZBnDuesEwcHe0xcRsMK0UxJt0VLfRyUATxvV9K1c_JZLJQTeFyGIDE3G8bes20UCJs3fg-MRk5_X-SyQGufNuP6X0daTOiGE-rDknKqnT4kq8e48yqrA5RQncHjHMuNN0WCXxVVkpc9KQQxQLLeH0RA1wfVJc_Mja59JMKLe7MrDWWr51G5ldHKdEWtxFfy5pDrYLSpGJyYzJGfeV2zeU0K0tBqEAHK23B);\n    background-color: #2463eb;\n    border-color: #2463eb\n    }</style>\n</head>\n<body class=\"bg-background-light dark:bg-background-dark font-display text-[#111318] dark:text-white overflow-x-hidden min-h-screen flex flex-col pb-20 md:pb-0\">\n<header class=\"sticky top-0 z-40 flex items-center justify-between whitespace-nowrap border-b border-solid border-b-[#f0f1f4] dark:border-gray-800 bg-surface-light dark:bg-surface-dark px-4 sm:px-10 py-3 shadow-sm\">\n<div class=\"flex items-center gap-3 sm:gap-4\">\n<div class=\"size-9 sm:size-10 flex items-center justify-center rounded-lg bg-primary/10 text-primary\">\n<span class=\"material-symbols-outlined text-xl sm:text-2xl\">school</span>\n</div>\n<div>\n<h2 class=\"text-[#111318] dark:text-white text-base sm:text-lg font-bold leading-tight tracking-[-0.015em]\">PPC Mastery</h2>\n<p class=\"text-xs sm:text-sm text-gray-500 dark:text-gray-400 font-medium truncate max-w-[140px] sm:max-w-none\">Mod 3: Advanced Targeting</p>\n</div>\n</div>\n<div class=\"hidden md:flex flex-1 justify-end gap-8 items-center\">\n<nav class=\"flex items-center gap-6\">\n<a class=\"text-[#111318] dark:text-gray-200 text-sm font-medium leading-normal hover:text-primary transition-colors\" href=\"#\">Dashboard</a>\n<a class=\"text-primary text-sm font-bold leading-normal\" href=\"#\">Quiz</a>\n<a class=\"text-[#111318] dark:text-gray-200 text-sm font-medium leading-normal hover:text-primary transition-colors\" href=\"#\">Community</a>\n<a class=\"text-[#111318] dark:text-gray-200 text-sm font-medium leading-normal hover:text-primary transition-colors\" href=\"#\">Profile</a>\n</nav>\n<div class=\"h-6 w-px bg-gray-200 dark:bg-gray-700\"></div>\n<div class=\"flex items-center gap-3\">\n<button class=\"flex items-center justify-center size-10 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors text-gray-600 dark:text-gray-300\">\n<span class=\"material-symbols-outlined\">notifications</span>\n</button>\n<div class=\"bg-center bg-no-repeat aspect-square bg-cover rounded-full size-9 border-2 border-white dark:border-gray-700 shadow-sm\" data-alt=\"User profile picture\" style='background-image: url(\"https://lh3.googleusercontent.com/aida-public/AB6AXuC4SuKpjESFY3PT6qFuGoamSxhkeoPZUF-MAw4aiRn6MSIqtu2jQH2XOSjyQ0ErlFTLcyOx9bK2o6xxXlId7ogtz_3SFxVFgTzz5rI7OziDFQxMe_3te8nYiPcJ79XyzYSP4PEVc0NDiU6kj_XPczRyMoZ0-tkiqeCsvwhJUY0fzccHYFuqFmGFnvwYVBYJlYfwF9k1t-NoEyw5rBc6CFYig7Ve09Ys--AR6KaOF4Ab3HhmceUI77qw9wMIFoiFABDhuCqTJd0ViNxs\");'>\n</div>\n</div>\n</div>\n<div class=\"md:hidden flex items-center gap-3\">\n<div class=\"bg-center bg-no-repeat aspect-square bg-cover rounded-full size-8 border border-gray-200 dark:border-gray-700\" style='background-image: url(\"https://lh3.googleusercontent.com/aida-public/AB6AXuC4SuKpjESFY3PT6qFuGoamSxhkeoPZUF-MAw4aiRn6MSIqtu2jQH2XOSjyQ0ErlFTLcyOx9bK2o6xxXlId7ogtz_3SFxVFgTzz5rI7OziDFQxMe_3te8nYiPcJ79XyzYSP4PEVc0NDiU6kj_XPczRyMoZ0-tkiqeCsvwhJUY0fzccHYFuqFmGFnvwYVBYJlYfwF9k1t-NoEyw5rBc6CFYig7Ve09Ys--AR6KaOF4Ab3HhmceUI77qw9wMIFoiFABDhuCqTJd0ViNxs\");'></div>\n<button class=\"text-gray-600 dark:text-white p-1\">\n<span class=\"material-symbols-outlined\">menu</span>\n</button>\n</div>\n</header>\n<main class=\"flex-1 flex flex-col items-center justify-start sm:justify-center p-3 sm:p-6 md:py-10 w-full\">\n<div class=\"w-full max-w-3xl bg-surface-light dark:bg-surface-dark rounded-xl sm:rounded-2xl shadow-lg sm:shadow-xl border border-gray-100 dark:border-gray-800 overflow-hidden flex flex-col\">\n<div class=\"px-4 sm:px-10 pt-6 sm:pt-8 pb-4 border-b border-gray-100 dark:border-gray-800/50\">\n<div class=\"flex flex-wrap gap-4 justify-between items-end mb-3\">\n<div>\n<p class=\"text-gray-500 dark:text-gray-400 text-[10px] sm:text-xs font-bold uppercase tracking-wider mb-1\">Quiz Progress</p>\n<p class=\"text-[#111318] dark:text-white text-sm sm:text-base font-bold leading-normal flex items-center gap-2\">\n                            Question 2 <span class=\"text-gray-400 font-normal\">of 5</span>\n</p>\n</div>\n<span class=\"inline-flex items-center justify-center bg-primary/10 text-primary text-[10px] sm:text-xs font-bold px-2 py-1 rounded\">\n                        40% Complete\n                    </span>\n</div>\n<div class=\"relative h-2 w-full bg-gray-100 dark:bg-gray-700 rounded-full overflow-hidden\">\n<div class=\"absolute top-0 left-0 h-full bg-primary rounded-full transition-all duration-500 ease-out\" style=\"width: 40%;\"></div>\n</div>\n</div>\n<div class=\"flex-1 overflow-y-auto px-4 sm:px-10 py-5 sm:py-6\">\n<div class=\"mb-6 sm:mb-8\">\n<span class=\"inline-block px-3 py-1 rounded-full bg-blue-50 dark:bg-blue-900/30 text-primary dark:text-blue-300 text-[10px] sm:text-xs font-bold mb-3 sm:mb-4 border border-blue-100 dark:border-blue-800\">\n                        Topic: Match Types\n                    </span>\n<h1 class=\"text-[#111318] dark:text-white text-xl sm:text-[28px] font-extrabold leading-snug sm:leading-tight tracking-tight\">\n                        Which match type should you use to discover new high-performing search terms that you haven't explicitly targeted?\n                    </h1>\n</div>\n<div class=\"flex flex-col gap-3 sm:gap-4\">\n<label class=\"group relative flex items-start gap-3 sm:gap-4 rounded-xl border-2 border-transparent bg-gray-50 dark:bg-gray-800/50 p-4 sm:p-5 cursor-pointer hover:bg-white dark:hover:bg-gray-800 hover:border-gray-200 dark:hover:border-gray-600 hover:shadow-md transition-all duration-200 active:scale-[0.99]\">\n<div class=\"mt-0.5\">\n<input class=\"custom-radio h-5 w-5 border-2 border-gray-300 text-primary focus:ring-primary focus:ring-offset-0 bg-transparent\" name=\"quiz-answer\" type=\"radio\"/>\n</div>\n<div class=\"flex grow flex-col\">\n<p class=\"text-[#111318] dark:text-white text-sm sm:text-base font-bold leading-snug mb-0.5 sm:mb-1\">Exact Match</p>\n<p class=\"text-gray-500 dark:text-gray-400 text-xs sm:text-sm font-normal leading-relaxed\">Targets specific keywords precisely, limiting exposure.</p>\n</div>\n</label>\n<label class=\"group relative flex items-start gap-3 sm:gap-4 rounded-xl border-2 border-primary bg-primary/[0.03] dark:bg-primary/[0.05] p-4 sm:p-5 cursor-pointer shadow-sm transition-all duration-200 active:scale-[0.99]\">\n<div class=\"mt-0.5\">\n<input checked=\"\" class=\"custom-radio h-5 w-5 border-2 border-gray-300 text-primary focus:ring-primary focus:ring-offset-0 bg-transparent\" name=\"quiz-answer\" type=\"radio\"/>\n</div>\n<div class=\"flex grow flex-col\">\n<p class=\"text-primary dark:text-blue-400 text-sm sm:text-base font-bold leading-snug mb-0.5 sm:mb-1\">Broad Match</p>\n<p class=\"text-gray-600 dark:text-gray-300 text-xs sm:text-sm font-normal leading-relaxed\">Triggers ads for variations, synonyms, and related searches.</p>\n</div>\n<div class=\"absolute right-3 top-3 sm:right-4 sm:top-4 text-primary opacity-100\">\n<span class=\"material-symbols-outlined text-xl\">check_circle</span>\n</div>\n</label>\n<label class=\"group relative flex items-start gap-3 sm:gap-4 rounded-xl border-2 border-transparent bg-gray-50 dark:bg-gray-800/50 p-4 sm:p-5 cursor-pointer hover:bg-white dark:hover:bg-gray-800 hover:border-gray-200 dark:hover:border-gray-600 hover:shadow-md transition-all duration-200 active:scale-[0.99]\">\n<div class=\"mt-0.5\">\n<input class=\"custom-radio h-5 w-5 border-2 border-gray-300 text-primary focus:ring-primary focus:ring-offset-0 bg-transparent\" name=\"quiz-answer\" type=\"radio\"/>\n</div>\n<div class=\"flex grow flex-col\">\n<p class=\"text-[#111318] dark:text-white text-sm sm:text-base font-bold leading-snug mb-0.5 sm:mb-1\">Phrase Match</p>\n<p class=\"text-gray-500 dark:text-gray-400 text-xs sm:text-sm font-normal leading-relaxed\">Includes the phrase and close variations but restricts order.</p>\n</div>\n</label>\n</div>\n<div class=\"mt-6 sm:mt-8 animate-fade-in\">\n<div class=\"flex flex-col gap-3 sm:gap-4 p-4 sm:p-5 rounded-xl bg-green-50 dark:bg-green-900/10 border border-green-200 dark:border-green-800/50 mb-3 sm:mb-4\">\n<div class=\"flex items-center gap-3\">\n<div class=\"flex items-center justify-center size-7 sm:size-8 rounded-full bg-green-100 dark:bg-green-900 text-green-600 dark:text-green-400 shrink-0\">\n<span class=\"material-symbols-outlined text-lg sm:text-xl\">check</span>\n</div>\n<h3 class=\"text-green-800 dark:text-green-200 text-base sm:text-lg font-bold\">Excellent! Correct.</h3>\n</div>\n<p class=\"text-green-700 dark:text-green-300 text-xs sm:text-sm leading-relaxed pl-10 sm:pl-11\">\n                            Broad match is the widest net you can cast. It is designed specifically for the <strong>discovery phase</strong>.\n                        </p>\n</div>\n<div class=\"flex gap-3 sm:gap-4 p-4 sm:p-5 rounded-xl bg-indigo-50 dark:bg-indigo-900/10 border border-indigo-100 dark:border-indigo-800/30\">\n<div class=\"shrink-0 text-indigo-500 dark:text-indigo-400\">\n<span class=\"material-symbols-outlined\">lightbulb</span>\n</div>\n<div class=\"flex flex-col gap-1\">\n<p class=\"text-indigo-900 dark:text-indigo-100 text-xs font-bold uppercase tracking-wide\">AI Insight</p>\n<p class=\"text-indigo-800 dark:text-indigo-200 text-xs sm:text-sm leading-relaxed\">\n<strong>Pro Tip:</strong> Broad Match can be expensive. Always pair it with a strong <strong>Negative Keyword</strong> list.\n                            </p>\n</div>\n</div>\n</div>\n</div>\n<div class=\"p-4 sm:p-6 sm:px-10 border-t border-gray-100 dark:border-gray-800 bg-white dark:bg-surface-dark rounded-b-xl sm:rounded-b-2xl sticky bottom-0 z-10\">\n<div class=\"flex flex-col-reverse sm:flex-row gap-3 sm:gap-4 items-center justify-between\">\n<button class=\"text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 text-xs sm:text-sm font-bold flex items-center justify-center gap-2 px-4 py-2 rounded-lg transition-colors w-full sm:w-auto\">\n<span class=\"material-symbols-outlined text-lg\">flag</span>\n                        Report\n                    </button>\n<button class=\"flex w-full sm:w-auto min-w-[160px] cursor-pointer items-center justify-center overflow-hidden rounded-xl h-11 sm:h-12 px-8 bg-primary hover:bg-blue-700 text-white shadow-lg shadow-blue-500/20 transition-all duration-200 transform active:scale-95\">\n<span class=\"text-sm sm:text-base font-bold tracking-wide\">Next Question</span>\n<span class=\"material-symbols-outlined ml-2 text-lg sm:text-xl\">arrow_forward</span>\n</button>\n</div>\n</div>\n</div>\n</main>\n<nav class=\"fixed bottom-0 left-0 w-full z-50 bg-white dark:bg-surface-dark border-t border-gray-200 dark:border-gray-800 md:hidden pb-[env(safe-area-inset-bottom)]\">\n<div class=\"grid grid-cols-5 h-16 items-center\">\n<a class=\"flex flex-col items-center justify-center gap-1 text-gray-500 dark:text-gray-400 hover:text-primary transition-colors p-1\" href=\"#\">\n<span class=\"material-symbols-outlined text-[24px]\">home</span>\n<span class=\"text-[10px] font-medium leading-none\">Home</span>\n</a>\n<a class=\"flex flex-col items-center justify-center gap-1 text-gray-500 dark:text-gray-400 hover:text-primary transition-colors p-1\" href=\"#\">\n<span class=\"material-symbols-outlined text-[24px]\">menu_book</span>\n<span class=\"text-[10px] font-medium leading-none\">Courses</span>\n</a>\n<a class=\"flex flex-col items-center justify-center gap-1 text-gray-500 dark:text-gray-400 hover:text-primary transition-colors p-1\" href=\"#\">\n<span class=\"material-symbols-outlined text-[24px]\">groups</span>\n<span class=\"text-[10px] font-medium leading-none\">Community</span>\n</a>\n<a class=\"flex flex-col items-center justify-center gap-1 text-primary dark:text-blue-400 transition-colors p-1 relative\" href=\"#\">\n<span class=\"material-symbols-outlined text-[24px] fill-current\">monitoring</span>\n<span class=\"text-[10px] font-bold leading-none\">Progress</span>\n<span class=\"absolute top-1 right-3 size-2 rounded-full bg-red-500 border border-white dark:border-surface-dark\"></span>\n</a>\n<a class=\"flex flex-col items-center justify-center gap-1 text-gray-500 dark:text-gray-400 hover:text-primary transition-colors p-1\" href=\"#\">\n<span class=\"material-symbols-outlined text-[24px]\">person</span>\n<span class=\"text-[10px] font-medium leading-none\">Profile</span>\n</a>\n</div>\n</nav>\n\n</body></html>"
