  "htmlContent": "<!DOCTYPE html>\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Amazon PPC Academy - AI Training for VAs</title>\n<link href=\"https://fonts.googleapis.com\" rel=\"preconnect\"/>\n<link crossorigin=\"\" href=\"https://fonts.gstatic.com\" rel=\"preconnect\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        \"primary\": \"#2463eb\",\n                        \"background-light\": \"#f6f6f8\",\n                        \"background-dark\": \"#111621\",\n                        \"surface-light\": \"#ffffff\",\n                        \"surface-dark\": \"#1a2233\",\n                        \"text-main\": \"#111318\",\n                        \"text-muted\": \"#616e89\",\n                    },\n                    fontFamily: {\n                        \"display\": [\"Inter\", \"sans-serif\"],\n                        \"body\": [\"Inter\", \"sans-serif\"],\n                    },\n                    borderRadius: {\"DEFAULT\": \"0.25rem\", \"lg\": \"0.5rem\", \"xl\": \"0.75rem\", \"full\": \"9999px\"},\n                },\n            },\n        }\n    </script>\n<style type=\"text/tailwindcss\">\n        @layer utilities {\n            .mobile-safe-bottom {\n                padding-bottom: env(safe-area-inset-bottom);\n            }\n        }\n    </style>\n</head>\n<body class=\"bg-background-light dark:bg-background-dark font-display text-text-main dark:text-white antialiased selection:bg-primary selection:text-white pb-20\">\n<div class=\"relative flex h-auto min-h-screen w-full flex-col overflow-x-hidden\">\n<header class=\"sticky top-0 z-50 w-full border-b border-gray-200 bg-surface-light/95 backdrop-blur dark:bg-background-dark/95 dark:border-gray-800\">\n<div class=\"px-4 py-3 flex items-center justify-between mx-auto max-w-7xl\">\n<div class=\"flex items-center gap-3 text-text-main dark:text-white\">\n<div class=\"size-8 text-primary shrink-0\">\n<span class=\"material-symbols-outlined text-3xl\">school</span>\n</div>\n<h2 class=\"text-base font-bold leading-tight tracking-tight\">Amazon PPC Academy</h2>\n</div>\n<div class=\"hidden md:flex flex-1 justify-end gap-8 items-center\">\n<div class=\"flex items-center gap-6\">\n<a class=\"text-sm font-medium hover:text-primary transition-colors dark:text-gray-300 dark:hover:text-primary\" href=\"#curriculum\">Curriculum</a>\n<a class=\"text-sm font-medium hover:text-primary transition-colors dark:text-gray-300 dark:hover:text-primary\" href=\"#mentors\">Mentors</a>\n<a class=\"text-sm font-medium hover:text-primary transition-colors dark:text-gray-300 dark:hover:text-primary\" href=\"#testimonials\">Success Stories</a>\n<a class=\"text-sm font-medium hover:text-primary transition-colors dark:text-gray-300 dark:hover:text-primary\" href=\"#resources\">Resources</a>\n</div>\n<button class=\"flex min-w-[84px] cursor-pointer items-center justify-center overflow-hidden rounded-lg h-10 px-6 bg-primary hover:bg-blue-600 transition-colors text-white text-sm font-bold shadow-lg shadow-blue-500/20\">\n<span class=\"truncate\">Enroll Now</span>\n</button>\n</div>\n<button class=\"md:hidden text-text-main dark:text-white p-1 rounded hover:bg-gray-100 dark:hover:bg-gray-800\">\n<span class=\"material-symbols-outlined text-2xl\">menu</span>\n</button>\n</div>\n</header>\n<section class=\"w-full bg-surface-light dark:bg-background-dark py-8 md:py-20 lg:py-24\">\n<div class=\"px-4 md:px-10 mx-auto max-w-7xl\">\n<div class=\"flex flex-col-reverse md:flex-row gap-8 items-center\">\n<div class=\"flex flex-col gap-6 w-full md:w-1/2\">\n<div class=\"flex flex-col gap-4 text-left\">\n<span class=\"inline-block px-3 py-1 rounded-full bg-blue-100 text-primary text-[10px] font-bold uppercase tracking-wider w-fit dark:bg-blue-900/30 dark:text-blue-300\">\n                            New AI Curriculum Updated\n                        </span>\n<h1 class=\"text-3xl md:text-5xl lg:text-6xl font-black leading-tight tracking-tight text-text-main dark:text-white\">\n                            Master Amazon PPC with <span class=\"text-primary\">AI Strategies</span>\n</h1>\n<h2 class=\"text-base md:text-xl font-normal leading-relaxed text-text-muted dark:text-gray-400 max-w-xl\">\n                            The ultimate training designed for Filipino Virtual Assistants. Launch your career with industry-recognized certification and AI-powered campaign management skills.\n                        </h2>\n</div>\n<div class=\"flex flex-col gap-3 mt-2 w-full\">\n<button class=\"flex w-full cursor-pointer items-center justify-center rounded-lg h-12 px-6 bg-primary hover:bg-blue-600 transition-colors text-white text-base font-bold shadow-lg shadow-blue-500/30\">\n                            Enroll for Free\n                        </button>\n<button class=\"flex w-full cursor-pointer items-center justify-center rounded-lg h-12 px-6 bg-gray-100 hover:bg-gray-200 dark:bg-surface-dark dark:hover:bg-gray-800 transition-colors text-text-main dark:text-white text-base font-bold border border-transparent dark:border-gray-700\">\n                            View Syllabus\n                        </button>\n</div>\n<div class=\"mt-4 pt-6 border-t border-gray-100 dark:border-gray-800\">\n<p class=\"text-xs font-medium text-gray-400 mb-4 uppercase tracking-wide\">Trusted by 7-figure Sellers</p>\n<div class=\"flex gap-4 opacity-60 grayscale transition-all hover:grayscale-0 flex-wrap\">\n<div class=\"h-6 w-20 bg-gray-300 dark:bg-gray-700 rounded animate-pulse\" data-alt=\"Trusted partner logo placeholder\"></div>\n<div class=\"h-6 w-20 bg-gray-300 dark:bg-gray-700 rounded animate-pulse\" data-alt=\"Trusted partner logo placeholder\"></div>\n<div class=\"h-6 w-20 bg-gray-300 dark:bg-gray-700 rounded animate-pulse\" data-alt=\"Trusted partner logo placeholder\"></div>\n</div>\n</div>\n</div>\n<div class=\"w-full md:w-1/2\">\n<div class=\"relative w-full aspect-[4/3] rounded-2xl overflow-hidden shadow-2xl shadow-blue-900/10\">\n<div class=\"absolute inset-0 bg-gradient-to-tr from-primary/20 to-transparent mix-blend-overlay z-10\"></div>\n<div class=\"w-full h-full bg-center bg-cover\" data-alt=\"Professional Filipino Virtual Assistant working on dual monitors analyzing data\" style='background-image: url(\"https://lh3.googleusercontent.com/aida-public/AB6AXuCCHW0OAlDMzSjuec77ouTC7zIUYv0Oa2gYlPsS2LwX1-ow3_uUd_DDZHxXEy7kKpF6wrSCjWWON16VqHz_7UXgYyFfnuG8EAYi7V_OV7B98o9mA8EljcMYUrbI9si4N0rRT0rMdzq3JSb1VjxCzQS2sJpUYntSb5Ga-kYs2CIAhd_jG5iV9BXgtFCv1QKOvZk-dRvi6Hirdnt8ZWMm6PU_IRVhwAkG6Dad2MHBYhjpRpkP1UsZRECbhtdeG5jTTbIawBkoYPz25ATG\");'>\n</div>\n<div class=\"absolute bottom-4 left-4 right-4 z-20 bg-white dark:bg-surface-dark p-3 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700 flex items-center gap-3\">\n<div class=\"bg-green-100 dark:bg-green-900/30 p-2 rounded-full text-green-600 dark:text-green-400 shrink-0\">\n<span class=\"material-symbols-outlined text-xl\">trending_up</span>\n</div>\n<div>\n<p class=\"text-[10px] text-gray-500 dark:text-gray-400 font-medium\">Average Salary Increase</p>\n<p class=\"text-base font-bold text-gray-900 dark:text-white\">+150%</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n</section>\n<section class=\"w-full bg-background-light dark:bg-background-dark py-8 border-y border-gray-200 dark:border-gray-800\">\n<div class=\"px-4 mx-auto max-w-7xl\">\n<div class=\"grid grid-cols-1 gap-4\">\n<div class=\"flex flex-col items-center gap-1 p-6 bg-white dark:bg-surface-dark rounded-xl shadow-sm border border-gray-100 dark:border-gray-800\">\n<div class=\"flex items-center gap-2 mb-2 text-primary\">\n<span class=\"material-symbols-outlined\">groups</span>\n<span class=\"text-xs font-bold uppercase tracking-wider\">Active Students</span>\n</div>\n<p class=\"text-3xl font-black text-text-main dark:text-white\">5,000+</p>\n<p class=\"text-xs text-text-muted dark:text-gray-400\">Enrolled across the Philippines</p>\n</div>\n<div class=\"flex flex-col items-center gap-1 p-6 bg-white dark:bg-surface-dark rounded-xl shadow-sm border border-gray-100 dark:border-gray-800\">\n<div class=\"flex items-center gap-2 mb-2 text-primary\">\n<span class=\"material-symbols-outlined\">work</span>\n<span class=\"text-xs font-bold uppercase tracking-wider\">Hired Rate</span>\n</div>\n<p class=\"text-3xl font-black text-text-main dark:text-white\">98%</p>\n<p class=\"text-xs text-text-muted dark:text-gray-400\">Within 3 months of certification</p>\n</div>\n<div class=\"flex flex-col items-center gap-1 p-6 bg-white dark:bg-surface-dark rounded-xl shadow-sm border border-gray-100 dark:border-gray-800\">\n<div class=\"flex items-center gap-2 mb-2 text-primary\">\n<span class=\"material-symbols-outlined\">library_books</span>\n<span class=\"text-xs font-bold uppercase tracking-wider\">Training Modules</span>\n</div>\n<p class=\"text-3xl font-black text-text-main dark:text-white\">50+</p>\n<p class=\"text-xs text-text-muted dark:text-gray-400\">Covering Basic to Advanced AI PPC</p>\n</div>\n</div>\n</div>\n</section>\n<section class=\"w-full bg-surface-light dark:bg-background-dark py-12\" id=\"curriculum\">\n<div class=\"px-4 mx-auto max-w-7xl\">\n<div class=\"flex flex-col gap-8\">\n<div class=\"flex flex-col gap-3 max-w-2xl\">\n<h2 class=\"text-2xl font-black leading-tight text-text-main dark:text-white\">\n                        Why Choose Our AI-Powered Training?\n                    </h2>\n<p class=\"text-base text-text-muted dark:text-gray-400\">\n                        Designed specifically for the modern Virtual Assistant landscape. We don't just teach you the basics; we teach you how to dominate using technology.\n                    </p>\n</div>\n<div class=\"grid grid-cols-1 gap-6\">\n<div class=\"flex flex-col gap-4 p-6 rounded-2xl bg-background-light dark:bg-surface-dark border border-gray-100 dark:border-gray-800 hover:border-primary/50 transition-all\">\n<div class=\"size-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary\">\n<span class=\"material-symbols-outlined text-2xl\">psychology</span>\n</div>\n<div class=\"flex flex-col gap-2\">\n<h3 class=\"text-lg font-bold text-text-main dark:text-white\">AI-Driven Analysis</h3>\n<p class=\"text-sm text-text-muted dark:text-gray-400 leading-relaxed\">\n                                Learn to leverage the latest AI tools (ChatGPT, Claude, specialized Amazon bots) to optimize campaigns 10x faster.\n                            </p>\n</div>\n</div>\n<div class=\"flex flex-col gap-4 p-6 rounded-2xl bg-background-light dark:bg-surface-dark border border-gray-100 dark:border-gray-800 hover:border-primary/50 transition-all\">\n<div class=\"size-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary\">\n<span class=\"material-symbols-outlined text-2xl\">verified</span>\n</div>\n<div class=\"flex flex-col gap-2\">\n<h3 class=\"text-lg font-bold text-text-main dark:text-white\">Certified Curriculum</h3>\n<p class=\"text-sm text-text-muted dark:text-gray-400 leading-relaxed\">\n                                Study a syllabus built by 7-figure sellers that meets current 2024 industry standards.\n                            </p>\n</div>\n</div>\n<div class=\"flex flex-col gap-4 p-6 rounded-2xl bg-background-light dark:bg-surface-dark border border-gray-100 dark:border-gray-800 hover:border-primary/50 transition-all\">\n<div class=\"size-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary\">\n<span class=\"material-symbols-outlined text-2xl\">handshake</span>\n</div>\n<div class=\"flex flex-col gap-2\">\n<h3 class=\"text-lg font-bold text-text-main dark:text-white\">Career Placement</h3>\n<p class=\"text-sm text-text-muted dark:text-gray-400 leading-relaxed\">\n                                Top graduates get matched directly with Amazon sellers in our partner network looking for certified PPC specialists.\n                            </p>\n</div>\n</div>\n</div>\n</div>\n</div>\n</section>\n<section class=\"w-full bg-primary/5 dark:bg-surface-dark py-12\">\n<div class=\"px-4 mx-auto max-w-7xl\">\n<div class=\"grid grid-cols-1 gap-10 items-center\">\n<div class=\"flex flex-col gap-6\">\n<div>\n<h2 class=\"text-2xl font-black text-text-main dark:text-white mb-3\">What You Will Learn</h2>\n<p class=\"text-sm text-text-muted dark:text-gray-400\">Our comprehensive curriculum takes you from beginner to expert in 6 weeks.</p>\n</div>\n<div class=\"space-y-4\">\n<div class=\"flex items-start gap-3\">\n<div class=\"mt-0.5 size-5 rounded-full bg-primary text-white flex items-center justify-center shrink-0\">\n<span class=\"material-symbols-outlined text-xs\">check</span>\n</div>\n<div>\n<h4 class=\"font-bold text-sm text-text-main dark:text-white\">Amazon PPC Fundamentals</h4>\n<p class=\"text-xs text-text-muted dark:text-gray-400 mt-1\">Understanding Sponsored Products, Brands, and Display ads.</p>\n</div>\n</div>\n<div class=\"flex items-start gap-3\">\n<div class=\"mt-0.5 size-5 rounded-full bg-primary text-white flex items-center justify-center shrink-0\">\n<span class=\"material-symbols-outlined text-xs\">check</span>\n</div>\n<div>\n<h4 class=\"font-bold text-sm text-text-main dark:text-white\">Keyword Research with AI</h4>\n<p class=\"text-xs text-text-muted dark:text-gray-400 mt-1\">Using advanced algorithms to find high-converting keywords.</p>\n</div>\n</div>\n<div class=\"flex items-start gap-3\">\n<div class=\"mt-0.5 size-5 rounded-full bg-primary text-white flex items-center justify-center shrink-0\">\n<span class=\"material-symbols-outlined text-xs\">check</span>\n</div>\n<div>\n<h4 class=\"font-bold text-sm text-text-main dark:text-white\">Campaign Optimization Logic</h4>\n<p class=\"text-xs text-text-muted dark:text-gray-400 mt-1\">Bid management, negative keyword strategies, and scaling winners.</p>\n</div>\n</div>\n<div class=\"flex items-start gap-3\">\n<div class=\"mt-0.5 size-5 rounded-full bg-primary text-white flex items-center justify-center shrink-0\">\n<span class=\"material-symbols-outlined text-xs\">check</span>\n</div>\n<div>\n<h4 class=\"font-bold text-sm text-text-main dark:text-white\">Reporting &amp; Client Communication</h4>\n<p class=\"text-xs text-text-muted dark:text-gray-400 mt-1\">How to present data to clients to justify your value.</p>\n</div>\n</div>\n</div>\n<div class=\"pt-2\">\n<button class=\"text-primary font-bold text-sm hover:underline inline-flex items-center gap-1 group\">\n                            View Full Curriculum \n                            <span class=\"material-symbols-outlined text-sm group-hover:translate-x-1 transition-transform\">arrow_forward</span>\n</button>\n</div>\n</div>\n<div class=\"relative w-full\">\n<div class=\"absolute -inset-2 bg-primary/20 rounded-2xl rotate-2 blur-sm\"></div>\n<div class=\"relative rounded-xl overflow-hidden shadow-2xl bg-white dark:bg-gray-900 border border-gray-100 dark:border-gray-800\">\n<div class=\"aspect-video w-full bg-cover bg-center\" data-alt=\"Group of students looking at a laptop screen learning together\" style='background-image: url(\"https://lh3.googleusercontent.com/aida-public/AB6AXuCleV3jzCRJDNxX5BXP2ID1hjCXqmu9Dblyv1wGTGly4Lr9TITLtQ16Gy48g0jAf2r9M1LRbBxd7BHeNl8i9FDu1tObMTUlOguZrTBv5snSsXj89Ro7CSvFJ7CiWBbG_BSzpkFe64KunLanaUSBtD573krGMBf8yGygy47YNJcMhme1v5DvM4gcOuxwg5ACAR6O3yzbtSnG3uoydZGZn9jwFiTCK7xdtPOM7LH3ML4G0FaP4G8dZ005C3wxCFULw0sZkXF8Snl4eduJ\");'>\n</div>\n<div class=\"p-4 bg-white dark:bg-surface-dark\">\n<div class=\"flex items-center gap-3 mb-2\">\n<div class=\"h-1.5 flex-1 bg-gray-100 dark:bg-gray-700 rounded-full overflow-hidden\">\n<div class=\"h-full w-3/4 bg-primary rounded-full\"></div>\n</div>\n<span class=\"text-[10px] font-bold text-primary\">75%</span>\n</div>\n<h3 class=\"text-sm font-bold text-text-main dark:text-white\">Module 4: Automated Bidding Rules</h3>\n<p class=\"text-[10px] text-text-muted dark:text-gray-400 mt-0.5\">Instructor: Sarah Jenkins</p>\n</div>\n</div>\n</div>\n</div>\n</div>\n</section>\n<section class=\"w-full bg-surface-light dark:bg-background-dark py-12\" id=\"testimonials\">\n<div class=\"px-4 mx-auto max-w-7xl\">\n<div class=\"text-center mb-10 max-w-3xl mx-auto\">\n<h2 class=\"text-2xl font-black text-text-main dark:text-white mb-3\">Success Stories</h2>\n<p class=\"text-base text-text-muted dark:text-gray-400\">Join thousands of VAs who have transformed their careers.</p>\n</div>\n<div class=\"grid grid-cols-1 gap-6\">\n<div class=\"bg-white dark:bg-surface-dark p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 flex flex-col h-full\">\n<div class=\"flex text-yellow-400 mb-3 text-sm\">\n<span class=\"material-symbols-outlined fill-current text-lg\">star</span>\n<span class=\"material-symbols-outlined fill-current text-lg\">star</span>\n<span class=\"material-symbols-outlined fill-current text-lg\">star</span>\n<span class=\"material-symbols-outlined fill-current text-lg\">star</span>\n<span class=\"material-symbols-outlined fill-current text-lg\">star</span>\n</div>\n<p class=\"text-sm text-text-main dark:text-gray-300 mb-4 flex-grow italic\">\"This course doubled my hourly rate as a VA! I went from doing general admin tasks for $5/hr to managing PPC campaigns for $15/hr.\"</p>\n<div class=\"flex items-center gap-3 mt-auto\">\n<div class=\"size-10 rounded-full bg-gray-200 dark:bg-gray-700 bg-cover bg-center\" data-alt=\"Portrait of Maria S