border border-primary/10 flex items-start gap-3\">\n<div class=\"flex-shrink-0 mt-0.5 text-primary\">\n<span class=\"material-symbols-outlined text-[24px]\">local_offer</span>\n</div>\n<div>\n<p class=\"text-sm font-bold text-slate-900 dark:text-white\">Special Offer for New VAs!</p>\n<p class=\"text-xs text-slate-600 dark:text-slate-400 mt-0.5\">\n                            Sign up today and get the <span class=\"font-semibold text-primary\">\"PPC Basics\"</span> module completely free.\n                        </p>\n</div>\n</div>\n<!-- Security Badge -->\n<div class=\"mt-8 flex items-center justify-center gap-1.5 opacity-60\">\n<span class=\"material-symbols-outlined text-[16px] text-slate-400\">lock</span>\n<span class=\"text-xs text-slate-400\">Secure SSL Connection</span>\n</div>\n</div>\n</div>\n<!-- Right Column: Visual / Branding -->\n<div class=\"hidden lg:flex lg:w-1/2 relative bg-surface-light dark:bg-surface-dark items-center justify-center overflow-hidden\">\n<!-- Background Image -->\n<div class=\"absolute inset-0 bg-cover bg-center z-0\" data-alt=\"Modern analytics dashboard interface on a laptop screen showing growth charts\" style='background-image: url(\"https://lh3.googleusercontent.com/aida-public/AB6AXuCkxGX0GtqgVhtPL1ITKVl30zfUFR2mzu5sMELH6p0GT5V063jwdRchqKxYOAWvbzz3kc-P4oEskKsUkNmz3Cr0P1xWejMhWS5nwTvrfjI4eLHeWXXm4v-vqqnOA6ONxNaQ5uudIkN7uPUI9O2OEQK67hj1WETtEQx4gn9xXNX7eOSZbJbjr0VPu6efZ_0Jh7v7xEFPLEyMO41MK5ROMwqhtRbiPR3d3FAs4zrHfndzwvIlx6rzqw44E6vpG7eICM6sWNsO0fE1jRNC\");'>\n</div>\n<!-- Overlay Gradient -->\n<div class=\"absolute inset-0 bg-gradient-to-t from-background-dark/90 via-background-dark/50 to-primary/20 z-10\"></div>\n<!-- Content on top of image -->\n<div class=\"relative z-20 max-w-lg p-12 text-white\">\n<div class=\"w-16 h-16 rounded-2xl bg-white/10 backdrop-blur-md flex items-center justify-center mb-8 border border-white/20\">\n<span class=\"material-symbols-outlined text-4xl text-white\">trending_up</span>\n</div>\n<h2 class=\"text-4xl font-bold mb-4 tracking-tight\">Master Amazon PPC &amp; Scale Your Career</h2>\n<p class=\"text-lg text-slate-200 leading-relaxed font-light\">\n                    Join thousands of Filipino Virtual Assistants transforming their skills into high-income opportunities. Access world-class training, real-time analytics tools, and a supportive community.\n                </p>\n<!-- Testimonial / Social Proof Pill -->\n<div class=\"mt-10 flex items-center gap-4\">\n<div class=\"flex -space-x-3\">\n<img alt=\"User Avatar\" class=\"w-10 h-10 rounded-full border-2 border-white/20\" data-alt=\"Portrait of a smiling young professional woman\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBcrHb9gpnByNbmmsVVv5AZLuCGd91pZXXAeQNtdE3kg2NHCllySfANeFUkB60PIKa_E_8k7bKn8BN18ynNWmzNGed0G2cU3D3tPKF-N6Lb3TmDFS8D8vxkP02KBjzpuV1sIWn_25px2SMbxNl2cPG60K8l1mzFNRPHOIUWG0vGtiWWYox5zhZvt11tq2c8rarwdSnoraMi6oIdoxgfeG3Sq5j5m7I4cqiafLRb2sGzsBz8wz7LapbJvJQut4XTjnAvKrb2dZWsGz3e\"/>\n<img alt=\"User Avatar\" class=\"w-10 h-10 rounded-full border-2 border-white/20\" data-alt=\"Portrait of a young professional man\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuBE953De5dGM2i24eVdnZ2kNvjrBuJNgh18pNgzReHyczRqvx9AUFdRL5wkWgrSQw7JqfpBpiDPaS-CihNAO9pW60TdNBNXgLbE3276BsmD9wsDcZualAGa61cessYXkJEzESmhJE9oQ4vAxGN8OlORudMGQjF9f2geifLKJtj9sP88w1r76EMtryoO3eIjM49eCBO2mfAU1mNL8XXsRrrTXKZh4s_yT6afbHUhwx7heSnMfW6ja-gZtkj714EiuEQYQObZTM0Dz6Pt\"/>\n<img alt=\"User Avatar\" class=\"w-10 h-10 rounded-full border-2 border-white/20\" data-alt=\"Portrait of a smiling man wearing glasses\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDcTppaXSI4l3KHsjTzyn5vR10vd5mtka_3rjxp5uuCbipN1AGyxBLVrrDveBSs5r0-15YTIxSVmW_dIFbLap_d3y0WRyzm70j4rb6DcFejhHkU4b6saJzRDJW0c-Au4MKZe335NpM65mrWGG571YYqWj5Y5F0KfJBPBp80oNLmjVGv6EEVg6RAkSciCuNrJNuy602uMFwTT8Jq7j9S5nD3lgQNuro75-c__iA3QCeKrpWQ5SHvnnYMmoLxujrcFl6DAymA3be38J8U\"/>\n<div class=\"w-10 h-10 rounded-full border-2 border-white/20 bg-primary flex items-center justify-center text-xs font-bold\">+2k</div>\n</div>\n<div class=\"flex flex-col\">\n<div class=\"flex text-yellow-400 text-sm\">\n<span class=\"material-symbols-outlined text-[16px] fill-current\">star</span>\n<span class=\"material-symbols-outlined text-[16px] fill-current\">star</span>\n<span class=\"material-symbols-outlined text-[16px] fill-current\">star</span>\n<span class=\"material-symbols-outlined text-[16px] fill-current\">star</span>\n<span class=\"material-symbols-outlined text-[16px] fill-current\">star</span>\n</div>\n<span class=\"text-sm font-medium text-slate-300\">Trusted by VAs worldwide</span>\n</div>\n</div>\n</div>\n</div>\n</div>\n</body></html>"
