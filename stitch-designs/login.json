  "htmlContent": "<!DOCTYPE html>\n\n<html class=\"light\" lang=\"en\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Login - Amazon PPC Training</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com\" rel=\"preconnect\"/>\n<link crossorigin=\"\" href=\"https://fonts.gstatic.com\" rel=\"preconnect\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;900&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script>\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        \"primary\": \"#2463eb\",\n                        \"primary-hover\": \"#1d55d6\",\n                        \"background-light\": \"#f6f6f8\",\n                        \"background-dark\": \"#111621\",\n                        \"surface-light\": \"#ffffff\",\n                        \"surface-dark\": \"#1a212e\",\n                    },\n                    fontFamily: {\n                        \"display\": [\"Inter\", \"sans-serif\"],\n                        \"body\": [\"Inter\", \"sans-serif\"],\n                    },\n                    borderRadius: { \"DEFAULT\": \"0.25rem\", \"lg\": \"0.5rem\", \"xl\": \"0.75rem\", \"2xl\": \"1rem\", \"full\": \"9999px\" },\n                },\n            },\n        }\n    </script>\n</head>\n<body class=\"bg-background-light dark:bg-background-dark font-display antialiased text-slate-900 dark:text-white h-screen flex overflow-hidden selection:bg-primary selection:text-white\">\n<!-- Main